
{#
/**
 * @file
 * Miii's theme implementation for comments.
 */
#}

<article{{ attributes.addClass('js-comment single-comment') }}>
  {#
    Hide the "new" indicator by default, let a piece of JavaScript ask the
    server which comments are new for the user. Rendering the final "new"
    indicator here would break the render cache.
  #}
  {% if comment_user_pic %}
    <header class="comment-user-picture">
      {{ user_picture }}
      <mark class="hidden" data-comment-timestamp="{{ new_indicator_timestamp }}"></mark>
    </header>
  {% endif %}

  <div class="single-comment-content-body">
    {% if title %}
      {{ title_prefix }}
      <h3{{ title_attributes.addClass('single-comment-title') }}>{{ title }}</h3>
      {{ title_suffix }}
    {% endif %}

    <div class="single-comment-meta">
      <span>{{ author }} {{ created }}</span>
      {% if parent %}
        <p class="visually-hidden">{{ parent }}</p>
      {% endif %}
    </div> <!-- /.single-comment-meta -->

    <div{{ content_attributes.addClass('single-comment-content') }}>
      {{ content }}
    </div>
  </div> <!-- /.single-comment-content -->
</article>
